  "rp": {
    "hero_title": "退款及取消政策",
    "hero_sub": "取消条款、退款条件和处理程序",
    "effective_date": "<strong>生效日期：</strong>2026年2月26日 | <strong>最后更新：</strong>2026年2月26日",
