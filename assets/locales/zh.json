  "tos": {
    "hero_title": "服务条款",
    "hero_sub": "使用 AQUATHRILL 服务的条款和条件",
    "effective_date": "<strong>生效日期：</strong>2026年3月7日 | <strong>最后更新：</strong>2026年3月7日",
    "s1_title": "1. 简介",
    "s1_p1": "欢迎访问 AQUATHRILL 网站（『网站』），由 AQUATHRILL（『我们』）运营。访问本网站或预订我们的服务，即表示您（『用户』、『客户』）同意本服务条款的所有内容。如果您不接受这些条款，请停止使用本网站。",
    "s2_title": "2. 我们的服务",
    "s2_p1": "AQUATHRILL 提供迷你快艇租赁服务，用于蛋岛之旅和泰国普吉岛安达曼海域游览。服务包括：",
    "s2_li1": "自驾迷你快艇之旅（配有随船船长）",
    "s2_li2": "浮潜设备、救生衣和安全装备",
    "s2_li3": "岛上餐食（根据所选套餐）",
    "s2_li4": "全程意外保险",
    "s3_title": "3. 预订与付款",
    "s3_li1": "<strong>预订：</strong>预订仅在收到全额付款后方可确认。",
    "s3_li2": "<strong>付款方式：</strong>接受信用卡/借记卡（通过 Payso (PaySolutions) 支付网关）、银行转账和 QR PromptPay。",
    "s3_li3": "<strong>价格：</strong>网站上显示的价格以泰铢（THB）计价，可能会在不另行通知的情况下更改。",
    "s3_li4": "<strong>支付安全：</strong>信用卡信息通过获得 PCI DSS 认证的 Payso (PaySolutions) 系统处理。我们不存储您的信用卡信息。",
    "s4_title": "4. 取消与退款",
    "s4_p1": "取消和退款政策请参阅我们的<a href=\"../refund-policy/\" style=\"color: var(--primary);\">退款和取消预订政策</a>。摘要如下：",
    "s4_li1": "提前48小时以上取消：全额退款",
    "s4_li2": "不足48小时取消：不退款，但可改期一次",
    "s4_li3": "未到场：不退款且不可改期",
    "s5_title": "5. 参团条件",
    "s5_li1": "<strong>年龄：</strong>驾驶人须年满18岁。儿童全程须有监护人陪同。",
    "s5_li2": "<strong>健康：</strong>参与者须身体健康，无不适合水上活动的疾病。如有健康问题请提前告知。",
    "s5_li3": "<strong>酒精：</strong>严禁在驾驶快艇前后饮酒。",
    "s5_li4": "<strong>救生衣：</strong>在船上时所有参与者必须始终穿戴救生衣。",
    "s5_li5": "<strong>船长指示：</strong>参与者必须严格遵守船长和船员的所有指示。",
    "s6_title": "6. 责任限制",
    "s6_li1": "AQUATHRILL 不对不可抗力事件（如天气、自然灾害或政府命令）造成的损失承担责任。",
    "s6_li2": "我们不对旅途中丢失或损坏的个人物品负责。",
    "s6_li3": "因参与者故意或疏忽行为造成的损失由参与者自行承担。",
    "s7_title": "7. 知识产权",
    "s7_p1": "网站上的所有内容，包括文字、图片、标志、图形和软件，均为 AQUATHRILL 的财产，受知识产权法保护。未经书面许可，禁止复制、修改或传播。",
    "s8_title": "8. 网站使用",
    "s8_p1": "您同意：",
    "s8_li1": "在预订和注册时提供准确真实的信息",
    "s8_li2": "不将网站用于非法或不当目的",
    "s8_li3": "不尝试访问未经授权的系统或数据",
    "s8_li4": "负责维护您的用户账户安全",
    "s9_title": "9. 隐私",
    "s9_p1": "您的个人数据的收集、使用和保护受我们的<a href=\"../privacy-policy/\" style=\"color: var(--primary);\">隐私政策</a>约束，该政策是本服务条款的一部分。",
    "s10_title": "10. 适用法律",
    "s10_p1": "本服务条款受泰王国法律管辖。任何争议均受泰国法院管辖。",
    "s11_title": "11. 条款变更",
    "s11_p1": "我们保留随时更新这些条款的权利。变更在网站发布后立即生效。变更后继续使用我们的服务即表示接受更新后的条款。",
    "s12_title": "12. 联系我们",
    "s12_p1": "如果您对服务条款有任何疑问，请通过以下方式联系我们："
  }
